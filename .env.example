# ==========================================
# 智能金融投研 RAG 系统 - 环境变量模板
# 注意:
# 1. 请将本文件复制并重命名为 .env : `cp .env.example .env`
# 2. 填入你真实的 API_KEY 等敏感信息
# 3. .env 文件已加入 .gitignore，绝不要提交到 Git！
# ==========================================

# 1. 大模型 API 密钥 (通义千问)
# 去阿里云百炼控制台申请: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY="sk-your_dashscope_api_key_here"

# 2. LangChain 运行追踪配置 (企业级 Debug 必备，可选)
LANGCHAIN_TRACING_V2="false"
# 下面两行在需要开启调试时取消注释并填入真实 KEY
# LANGCHAIN_API_KEY="lsv2_your_langsmith_api_key_here"
# LANGCHAIN_PROJECT="financial_agentic_rag_dev"

# 3. 后端服务配置
API_HOST="0.0.0.0"
API_PORT="8000"

# ==========================================
# 4. 向量计算层 (Milvus V2)
# ==========================================
# 🌟 关键点：
# - 如果你是一键 docker-compose up 把后端应用和数据库一起启动的，这里请填 milvus 的服务名 (例如: milvus-standalone)
# - 如果你是本地跑 Python 脚本，只用 Docker 起了数据库，这里填 127.0.0.1
MILVUS_HOST="127.0.0.1"
MILVUS_PORT="19531"
COLLECTION_NAME="finance_reports_v3"

# ==========================================
# 5. 关系型存储层 (PostgreSQL) - 双库解耦
# ==========================================
# 🌟 同理，纯 Docker 组网部署时，请填 postgres 的服务名 (例如: postgres)；本地调试填 127.0.0.1
PG_HOST="127.0.0.1"
PG_PORT="5432"
PG_USER="rag_user"
PG_PASSWORD="your_secure_password" # 部署时请修改为安全密码
PG_DB="rag_db"